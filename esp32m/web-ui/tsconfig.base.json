{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "paths": {
      "@ts-libs/config": ["./ts-libs/config/src/index.ts"],
      "@ts-libs/dev": ["./ts-libs/dev/src/index.ts"],
      "@ts-libs/log": ["./ts-libs/log/src/index.ts"],
      "@ts-libs/plugins": ["./ts-libs/plugins/src/index.ts"],
      "@ts-libs/redux": ["./ts-libs/redux/src/index.ts"],
      "@ts-libs/tools": ["./ts-libs/tools/src/index.ts"],
      "@ts-libs/ui-app": ["./ts-libs/ui-app/src/index.ts"],
      "@ts-libs/ui-base": ["./ts-libs/ui-base/src/index.ts"],
      "@ts-libs/ui-forms": ["./ts-libs/ui-forms/src/index.ts"],
      "@ts-libs/ui-i18n": ["./ts-libs/ui-i18n/src/index.ts"],
      "@ts-libs/ui-navbar": ["./ts-libs/ui-navbar/src/index.ts"],
      "@ts-libs/ui-snack": ["./ts-libs/ui-snack/src/index.ts"]
    },
    "lib": ["dom", "ESNext"],
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "inlineSources": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "moduleResolution": "bundler",
    "strictNullChecks": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "useUnknownInCatchVariables": false,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jest", "node"],
    "jsx": "react-jsx",
    "experimentalDecorators": true
  }
}
